# -------------------------------------------------------
# J.A.R.G.I.I.N. – environment variables template
# Copy to .env and fill in your values.
# NEVER commit the real .env file.
# -------------------------------------------------------

# ── Server ──────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── LLM Provider API Keys ───────────────────────────────
# Only the keys you actually use need to be set.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Azure OpenAI (provide all three if using Azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=jargiin-primary
# Optional model-path deployment overrides (recommended when exposing GPT-5 family)
AZURE_OPENAI_DEPLOYMENT_GPT_5_5=
AZURE_OPENAI_DEPLOYMENT_GPT_5_MINI=jargiin-primary
AZURE_OPENAI_DEPLOYMENT_GPT_5_NANO=
# Optional override (default in app: 2025-04-01-preview)
AZURE_OPENAI_API_VERSION=

MISTRAL_API_KEY=

# OpenRouter (uses OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Local / self-hosted endpoint (e.g. Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434

# ── Default provider ────────────────────────────────────
# One of: openai | anthropic | gemini | azure | mistral | openrouter | ollama
# Default is Azure OpenAI (Foundry-compatible). If unavailable, backend falls back to OpenAI when configured.
DEFAULT_PROVIDER=azure

# ── Speech / STT ────────────────────────────────────────
# Provider: browser | openai-stt | deepgram | whisper-local
STT_PROVIDER=browser
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
DEEPGRAM_API_KEY=

# ── Speech / TTS ────────────────────────────────────────
# Provider: browser | azure-speech | openai-tts | elevenlabs | google-tts
TTS_PROVIDER=browser
OPENAI_TTS_MODEL=gpt-4o-mini-tts
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=canadaeast
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_VOICE=en-GB-SoniaNeural
ELEVENLABS_API_KEY=

# ── Privacy & Logging ───────────────────────────────────
# Set DEBUG_MODE=true to enable verbose logging (prompts, transcripts, responses).
# NEVER enable in production for real users.
DEBUG_MODE=false

# Retain transcripts on server: true | false
PERSIST_TRANSCRIPTS=false

# ── SharePoint-backed user settings persistence (Microsoft Graph) ─────────────
# App registration for Graph client credentials:
# - Application permission: Sites.Selected
# - Grant the app write access to your target SharePoint site.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# SharePoint target:
# SHAREPOINT_SITE_ID format: {hostname},{siteCollectionId},{siteId}
SHAREPOINT_SITE_ID=
SHAREPOINT_SETTINGS_FOLDER=JargiinSettings
