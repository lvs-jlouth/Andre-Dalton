# -------------------------------------------------------
# J.A.R.G.I.I.N. Assistant – environment variables template
# Copy to .env and fill in your values.
# NEVER commit the real .env file.
# -------------------------------------------------------

# ── Server ──────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Microsoft Entra ID (Azure AD) ───────────────────────
# Register an app at https://portal.azure.com → App registrations
# Required API permissions: User.Read, Files.ReadWrite, Files.ReadWrite.All,
#   Mail.ReadWrite, Mail.Send, Calendars.ReadWrite, Chat.ReadWrite, Presence.Read
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback

# Frontend Entra ID config (must be prefixed with VITE_ for Vite)
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback

# ── LLM Provider API Keys ───────────────────────────────
# Only the keys you actually use need to be set.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Azure OpenAI (provide all three if using Azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

MISTRAL_API_KEY=

# OpenRouter (uses OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Local / self-hosted endpoint (e.g. Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434

# ── Default provider ────────────────────────────────────
# One of: openai | anthropic | gemini | azure | mistral | openrouter | ollama
DEFAULT_PROVIDER=ollama

# ── Speech / STT ────────────────────────────────────────
# Provider: browser | deepgram | whisper-local
STT_PROVIDER=browser
DEEPGRAM_API_KEY=

# ── Speech / TTS ────────────────────────────────────────
# Provider: browser | elevenlabs | google-tts
TTS_PROVIDER=browser
ELEVENLABS_API_KEY=

# ── Privacy & Logging ───────────────────────────────────
# Set DEBUG_MODE=true to enable verbose logging (prompts, transcripts, responses).
# NEVER enable in production for real users.
DEBUG_MODE=false

# Retain transcripts on server: true | false
PERSIST_TRANSCRIPTS=false
